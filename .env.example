# Copia este archivo a .env y rellena los valores.
# .env está en .gitignore: NUNCA subas tus secretos al repositorio.

# --- Despliegue en testnet pública Sepolia (opcional) ---
# URL del nodo RPC (Alchemy, Infura, etc.)
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY"

# Clave privada de una cuenta SOLO de pruebas (con ETH de faucet, nunca fondos reales)
PRIVATE_KEY="0xtu_clave_privada_de_prueba"

# API key de Etherscan para verificar el contrato (opcional)
ETHERSCAN_API_KEY="tu_api_key_de_etherscan"
